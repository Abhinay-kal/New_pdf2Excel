#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
LOG_DIR="$ROOT_DIR/logs"
mkdir -p "$LOG_DIR"
TIMESTAMP="$(date +%Y%m%d_%H%M%S)"
LOG_FILE="$LOG_DIR/desktop_launcher_${TIMESTAMP}.log"

exec >"$LOG_FILE" 2>&1

echo "[$(date '+%Y-%m-%d %H:%M:%S')] Electra-Core desktop launcher started"
echo "[$(date '+%Y-%m-%d %H:%M:%S')] Project root: $ROOT_DIR"

notify_info() {
  local title="$1"
  local message="$2"
  /usr/bin/osascript -e "display notification \"${message}\" with title \"${title}\"" >/dev/null 2>&1 || true
}

show_error_dialog() {
  local message="$1"
  /usr/bin/osascript -e "display dialog \"${message}\" buttons {\"OK\"} default button \"OK\" with icon stop" >/dev/null 2>&1 || true
}

if ! command -v python3 >/dev/null 2>&1; then
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] ERROR: python3 not found in PATH"
  show_error_dialog "Python 3 is not installed. Please install Python 3 and retry. Log: $LOG_FILE"
  exit 1
fi

if [[ ! -f "$ROOT_DIR/requirements.txt" ]]; then
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] ERROR: requirements.txt not found"
  show_error_dialog "requirements.txt not found in project folder. Log: $LOG_FILE"
  exit 1
fi

if [[ -d "$ROOT_DIR/.venv" ]]; then
  VENV_DIR="$ROOT_DIR/.venv"
elif [[ -d "$ROOT_DIR/venv" ]]; then
  VENV_DIR="$ROOT_DIR/venv"
else
  VENV_DIR="$ROOT_DIR/.venv"
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] Creating virtual environment at $VENV_DIR"
  python3 -m venv "$VENV_DIR"
fi

# shellcheck disable=SC1091
source "$VENV_DIR/bin/activate"

echo "[$(date '+%Y-%m-%d %H:%M:%S')] Upgrading pip"
python -m pip install --upgrade pip

echo "[$(date '+%Y-%m-%d %H:%M:%S')] Installing dependencies"
python -m pip install -r "$ROOT_DIR/requirements.txt"

PDF_PATH="$(/usr/bin/osascript -e 'POSIX path of (choose file of type {"com.adobe.pdf"} with prompt "Select voter-roll PDF")' 2>/dev/null || true)"

if [[ -z "${PDF_PATH:-}" ]]; then
  shopt -s nullglob
  pdf_candidates=("$ROOT_DIR"/*.pdf)
  shopt -u nullglob
  if [[ ${#pdf_candidates[@]} -ge 1 ]]; then
    PDF_PATH="${pdf_candidates[0]}"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] No manual selection; using first project PDF: $PDF_PATH"
  fi
fi

if [[ -z "${PDF_PATH:-}" || ! -f "$PDF_PATH" ]]; then
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] ERROR: no valid PDF selected"
  show_error_dialog "No PDF selected. Please run again and pick a PDF. Log: $LOG_FILE"
  exit 1
fi

echo "[$(date '+%Y-%m-%d %H:%M:%S')] Running pipeline for PDF: $PDF_PATH"
cd "$ROOT_DIR"
if python main.py "$PDF_PATH"; then
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] SUCCESS"
  notify_info "Electra-Core" "Extraction complete. Log: $(basename "$LOG_FILE")"
else
  exit_code=$?
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] ERROR: pipeline exited with code $exit_code"
  show_error_dialog "Extraction failed (code $exit_code). See log: $LOG_FILE"
  exit "$exit_code"
fi
